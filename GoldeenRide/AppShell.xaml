<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GoldeenRide.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GoldeenRide.Views"
    FlyoutBehavior="{Binding FlyoutState}"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">

    <Shell.Resources>
        <Style TargetType="Button" x:Key="MenuBtnStyle">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" />
            <Setter Property="HorizontalOptions" Value="Fill" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20, 15" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </Shell.Resources>

    <Shell.FlyoutContent>
        <ScrollView>
            <VerticalStackLayout>

                <Grid HeightRequest="180" BackgroundColor="#121212" Padding="20">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Border WidthRequest="60" HeightRequest="60" StrokeShape="RoundRectangle 30" StrokeThickness="2" Stroke="{StaticResource Primary}" BackgroundColor="Transparent" HorizontalOptions="Start">
                            <Label Text="👤" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="{Binding UserName}" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,10,0,0"/>
                        <Label Text="{Binding UserEmail}" FontSize="13" TextColor="#AAAAAA"/>
                        <Label Text="{Binding UserRole}" FontSize="11" TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="0,10">
                    <Button Text="{StaticResource MenuHome}" Command="{Binding GoToHomeCommand}" IsVisible="{Binding IsLogged}" Style="{StaticResource MenuBtnStyle}" />
                    <Button Text="{StaticResource MenuProfile}" Command="{Binding GoToSettingsCommand}" IsVisible="{Binding IsLogged}" Style="{StaticResource MenuBtnStyle}" />

                    <Button Text="{StaticResource MenuAdminFleet}" Command="{Binding GoToAdminFleetCommand}" IsVisible="{Binding IsJefe}" Style="{StaticResource MenuBtnStyle}" />
                    <Button Text="{StaticResource MenuSchedule}" Command="{Binding GoToScheduleTripCommand}" IsVisible="{Binding IsJefe}" Style="{StaticResource MenuBtnStyle}" />

                    <Button Text="{StaticResource MenuMyVehicle}" Command="{Binding GoToAdminFleetCommand}" IsVisible="{Binding IsIndependiente}" Style="{StaticResource MenuBtnStyle}" />
                    <Button Text="{StaticResource MenuSchedule}" Command="{Binding GoToScheduleTripCommand}" IsVisible="{Binding IsIndependiente}" Style="{StaticResource MenuBtnStyle}" />

                    <Button Text="{StaticResource MenuJoinFleet}" Command="{Binding GoToSettingsCommand}" IsVisible="{Binding IsEmpleado}" Style="{StaticResource MenuBtnStyle}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Shell.FlyoutContent>

    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" FlyoutItemIsVisible="False" />
    <ShellContent Route="register-step1" ContentTemplate="{DataTemplate views:RegisterStep1Page}" FlyoutItemIsVisible="False" />
    <ShellContent Route="register-step2" ContentTemplate="{DataTemplate views:RegisterStep2Page}" FlyoutItemIsVisible="False" />
    <ShellContent Route="driver-dashboard" ContentTemplate="{DataTemplate views:DriverDashboardPage}" FlyoutItemIsVisible="False" />
    <ShellContent Route="passenger-dashboard" ContentTemplate="{DataTemplate views:PassengerDashboardPage}" FlyoutItemIsVisible="False" />

</Shell>