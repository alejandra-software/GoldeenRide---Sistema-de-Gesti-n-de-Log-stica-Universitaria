<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoldeenRide.Views.AdminFleetPage"
             xmlns:viewmodels="clr-namespace:GoldeenRide.ViewModels"
             Title="Mi Flota y Empleados">

    <ContentPage.BindingContext>
        <viewmodels:AdminFleetViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="20">

                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Mis Microbuses" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="+ Añadir" Command="{Binding AddVehicleCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="8" HeightRequest="35" Padding="15,0"/>
                </Grid>

                <Label Text="Aún no tienes microbuses registrados." IsVisible="{Binding Vehiculos.Count, Converter={StaticResource InvertedBoolConverter}}" TextColor="{StaticResource LightHint}" FontAttributes="Italic"/>

                <CollectionView ItemsSource="{Binding Vehiculos}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding Placa}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                                        <Label Text="{Binding Capacidad, StringFormat='Capacidad: {0} pasajeros'}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightDivider}, Dark={StaticResource DarkDivider}}" Margin="0,10"/>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Mis Choferes" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Button Grid.Column="1" Text="+ Vincular" Command="{Binding LinkEmployeeCommand}" BackgroundColor="{StaticResource SecondaryBlue}" TextColor="White" CornerRadius="8" HeightRequest="35" Padding="15,0"/>
                </Grid>

                <Label Text="No tienes choferes vinculados a tu flota." IsVisible="{Binding Empleados.Count, Converter={StaticResource InvertedBoolConverter}}" TextColor="{StaticResource LightHint}" FontAttributes="Italic"/>

                <CollectionView ItemsSource="{Binding Empleados}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                                    StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="0" BackgroundColor="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" Margin="0,0,15,0">
                                        <Label Text="👤" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                        <Label Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold"/>
                                        <Label Text="{Binding Email}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="50" HeightRequest="50"/>
    </Grid>
</ContentPage>