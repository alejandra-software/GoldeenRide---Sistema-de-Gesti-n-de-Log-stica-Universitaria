<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoldeenRide.Views.DriverDashboardPage"
             xmlns:viewmodels="clr-namespace:GoldeenRide.ViewModels"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="20,40,20,20" Spacing="24">

            <Grid ColumnDefinitions="Auto, Auto, *, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="15">

                <ImageButton Grid.RowSpan="2" Grid.Column="0" Command="{Binding OpenSidebarCommand}" BackgroundColor="Transparent" Padding="0,0,10,0">
                    <ImageButton.Source>
                        <FontImageSource FontFamily="OpenSansRegular" Glyph="☰" Size="28" Color="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"/>
                    </ImageButton.Source>
                </ImageButton>

                <Border Grid.RowSpan="2" Grid.Column="1" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 25" StrokeThickness="0" Padding="0" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSidebarCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="👤" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <HorizontalStackLayout Grid.Row="0" Grid.Column="2" Spacing="5" VerticalOptions="End">
                    <Label Text="Hola," FontSize="18" TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                    <Label Text="{Binding DriverName}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                </HorizontalStackLayout>

                <Label Grid.Row="1" Grid.Column="2" FontSize="13" TextColor="#D4AF37">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Vehículo: " />
                            <Span Text="{Binding AssignedVehicle}" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>

            <Border Stroke="#D4AF37" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1E1E1E}" StrokeThickness="2" StrokeShape="RoundRectangle 12" Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Próximo Viaje" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"/>

                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *" RowSpacing="10">
                        <Label Grid.Row="0" Grid.Column="0" Text="Tipo" FontSize="13" TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding NextTripType}" FontSize="14" FontAttributes="Bold" HorizontalOptions="End" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Salida" FontSize="13" TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding NextTripTime}" FontSize="14" FontAttributes="Bold" TextColor="#D4AF37" HorizontalOptions="End"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="Ruta" FontSize="13" TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding NextTripRoute}" FontSize="14" FontAttributes="Bold" HorizontalOptions="End" HorizontalTextAlignment="End" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                    </Grid>

                    <VerticalStackLayout Spacing="5" Margin="0,10,0,0" IsVisible="{Binding HasNextTrip}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="Ocupación" FontSize="13" TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                            <Label Grid.Column="1" Text="{Binding ReservedSeats}" FontSize="13" FontAttributes="Bold" HorizontalOptions="End" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>
                        </Grid>
                        <ProgressBar Progress="{Binding OccupancyProgress}" ProgressColor="#D4AF37" HeightRequest="6" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"/>
                    </VerticalStackLayout>

                    <Button Text="Lista de Pasajeros" IsVisible="{Binding HasNextTrip}" Command="{Binding OpenBoardingListCommand}" BackgroundColor="#D4AF37" TextColor="#000000" FontAttributes="Bold" CornerRadius="8" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Acciones Rápidas" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0" TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"/>

            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto" ColumnSpacing="15">
                <Button Grid.Column="0" Text="Programar" 
                        IsVisible="{Binding CanScheduleTrips}"
                        Command="{Binding OpenScheduleTripCommand}"
                        BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" CornerRadius="8"/>

                <Button Grid.Column="1" Text="Mis Rutas" 
                        BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A2A}"
                        TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" CornerRadius="8"/>
            </Grid>

            <VerticalStackLayout Spacing="10" Margin="0,10,0,0">
                <Button Text="Administrar Flota" IsVisible="{Binding IsFleetManager}" Command="{Binding OpenAdminFleetCommand}"
                        BackgroundColor="#000000" TextColor="#D4AF37" CornerRadius="8" FontAttributes="Bold" BorderColor="#D4AF37" BorderWidth="1"/>

                <Button Text="Mi Vehículo" IsVisible="{Binding IsIndependentDriver}"
                        BackgroundColor="#000000" TextColor="#D4AF37" CornerRadius="8" FontAttributes="Bold" BorderColor="#D4AF37" BorderWidth="1"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>