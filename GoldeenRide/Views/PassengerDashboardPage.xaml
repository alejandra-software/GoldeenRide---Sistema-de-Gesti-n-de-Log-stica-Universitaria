<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoldeenRide.Views.PassengerDashboardPage"
             xmlns:viewmodels="clr-namespace:GoldeenRide.ViewModels"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightBg}, Dark={StaticResource DarkBg}}">

    <ContentPage.BindingContext>
        <viewmodels:PassengerDashboardViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,40,20,20" Spacing="20">

                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                    <Border Grid.RowSpan="2" Grid.Column="0" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 25" StrokeThickness="0" Padding="0" BackgroundColor="{StaticResource Primary}">
                        <Label Text="🎓" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5" VerticalOptions="End">
                        <Label Text="Hola," FontSize="18" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                        <Label Text="{Binding StudentName}" FontSize="18" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Label Grid.Row="1" Grid.Column="1" Text="¿A dónde viajamos hoy?" FontSize="13" TextColor="{StaticResource Primary}"/>
                </Grid>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightDivider}, Dark={StaticResource DarkDivider}}"/>

                <Label Text="Ver viajes para la fecha:" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" StrokeShape="RoundRectangle 8" Padding="15,5" BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">
                    <DatePicker Date="{Binding FechaSeleccionada}" Format="dddd, dd MMMM yyyy" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}" FontAttributes="Bold"/>
                </Border>

                <Label Text="Viajes Disponibles" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0"/>

                <Label Text="No hay viajes programados para esta fecha." IsVisible="{Binding ViajesDisponibles.Count, Converter={StaticResource InvertedBoolConverter}}" TextColor="{StaticResource LightHint}" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,20,0,0"/>

                <CollectionView ItemsSource="{Binding ViajesDisponibles}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="{StaticResource Primary}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}" StrokeShape="RoundRectangle 12" Padding="20" Margin="0,0,0,15">
                                <VerticalStackLayout Spacing="10">

                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0" Text="{Binding TipoViaje}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"/>
                                        <Label Grid.Column="1" Text="{Binding HoraSalida, StringFormat='{0:hh\\:mm tt}'}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                                    </Grid>

                                    <Label Text="{Binding RutaGeneral, StringFormat='Ruta: {0}'}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>

                                    <Button Text="Reservar Asiento" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PassengerDashboardViewModel}}, Path=ReservarViajeCommand}" CommandParameter="{Binding .}" BackgroundColor="{StaticResource Primary}" TextColor="#000000" FontAttributes="Bold" CornerRadius="8" Margin="0,10,0,0"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="50" HeightRequest="50"/>
    </Grid>
</ContentPage>