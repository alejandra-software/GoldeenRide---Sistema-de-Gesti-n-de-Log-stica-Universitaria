<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoldeenRide.Views.RegisterStep1Page"
             Title="{StaticResource RegisterStep1Title}"
             Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,20,24,20" Spacing="16">

                <!-- Progreso -->
                <VerticalStackLayout Spacing="6" Margin="0,0,0,10">
                    <Label Text="{StaticResource RegisterStep1Subtitle}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                    <ProgressBar Progress="0.5" HeightRequest="4" ProgressColor="{StaticResource Primary}" BackgroundColor="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"/>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{StaticResource RegisterStep1Email}" FontSize="13" FontAttributes="Bold"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="4,0">
                        <Entry Text="{Binding RegisterEmail}" Placeholder="{StaticResource RegisterStep1EmailHint}" Keyboard="Email" FontSize="14"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Contraseña -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{StaticResource RegisterStep1Password}" FontSize="13" FontAttributes="Bold"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="4,0">
                        <Grid ColumnDefinitions="*, 44">
                            <Entry Grid.Column="0" Text="{Binding RegisterPassword}" IsPassword="{Binding IsRegisterPasswordHidden}" Placeholder="{StaticResource RegisterStep1PasswordHint}" FontSize="14"/>
                            <Label Grid.Column="1" Text="{Binding RegisterPasswordEyeIcon}" FontSize="22" VerticalOptions="Center" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRegisterPasswordCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Confirmar Contraseña -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{StaticResource RegisterStep1ConfirmPassword}" FontSize="13" FontAttributes="Bold"/>
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="4,0">
                        <Grid ColumnDefinitions="*, 44">
                            <Entry Grid.Column="0" Text="{Binding RegisterConfirmPassword}" IsPassword="{Binding IsRegisterConfirmPasswordHidden}" Placeholder="{StaticResource RegisterStep1ConfirmPassword}" FontSize="14"/>
                            <Label Grid.Column="1" Text="{Binding RegisterConfirmPasswordEyeIcon}" FontSize="22" VerticalOptions="Center" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleRegisterConfirmPasswordCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label Text="{Binding RegisterStep1ErrorMessage}" IsVisible="{Binding RegisterStep1ErrorMessage, Converter={StaticResource StringToBoolConverter}}" TextColor="{StaticResource Error}" FontSize="12"/>

                <Button Text="{StaticResource RegisterStep1NextButton}" Command="{Binding RegisterStep1NextCommand}" BackgroundColor="{StaticResource Primary}" TextColor="White" Padding="0,14" CornerRadius="8" FontSize="16" FontAttributes="Bold"
                        IsEnabled="{Binding IsRegisterStep1Loading, Converter={StaticResource InvertedBoolConverter}}" Margin="0,8,0,0"/>

                <ActivityIndicator IsRunning="{Binding IsRegisterStep1Loading}" IsVisible="{Binding IsRegisterStep1Loading}" Color="{StaticResource Primary}"/>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Padding="24,12,24,36" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource LightBg}, Dark={StaticResource DarkBg}}">
            <BoxView HeightRequest="1" Margin="0,0,0,4"/>
            <Label Text="{StaticResource RegisterStep1HaveAccount}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}" HorizontalOptions="Center"/>
            <Button Text="{StaticResource LoginTitle}" Command="{Binding GoToLoginCommand}" BackgroundColor="{StaticResource SecondaryBlue}" TextColor="White" Padding="0,13" CornerRadius="8" FontSize="14" FontAttributes="Bold"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>