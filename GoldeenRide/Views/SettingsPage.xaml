<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoldeenRide.Views.SettingsPage"
             xmlns:viewmodels="clr-namespace:GoldeenRide.ViewModels"
             Title="{StaticResource SettingsPageTitle}">

    <ContentPage.BindingContext>
        <viewmodels:SettingsViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- TARJETA DE PERFIL -->
                <Border Stroke="{StaticResource Primary}" BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}" StrokeThickness="2" StrokeShape="RoundRectangle 12" Padding="20">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                        <Border Grid.Column="0" WidthRequest="60" HeightRequest="60" StrokeShape="RoundRectangle 30" StrokeThickness="0" BackgroundColor="{StaticResource Primary}" VerticalOptions="Center">
                            <Label Text="👤" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="{Binding UserName}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"/>
                            <Label Text="{Binding UserRole}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}" TextTransform="Uppercase"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- SECCIÓN JEFE: Compartir Código -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsFleetManager}">
                    <Label Text="{StaticResource SettingsInviteTitle}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                    <Label Text="{StaticResource SettingsInviteDesc}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>

                    <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" StrokeShape="RoundRectangle 8" Padding="15,10" BackgroundColor="{AppThemeBinding Light={StaticResource LightButtonSec}, Dark={StaticResource DarkButtonSec}}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="{Binding MyFleetCode}" FontSize="12" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"/>
                            <Button Grid.Column="1" Text="{StaticResource SettingsCopyBtn}" Command="{Binding CopyFleetCodeCommand}" BackgroundColor="{StaticResource Primary}" TextColor="#000000" CornerRadius="6" Padding="10,0" HeightRequest="35"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- SECCIÓN EMPLEADO: Unirse a Flota -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsEmployee}">
                    <Label Text="{StaticResource SettingsMyFleetTitle}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>

                    <VerticalStackLayout Spacing="10" IsVisible="{Binding HasBoss, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="{StaticResource SettingsPasteDesc}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                        <Border Stroke="{AppThemeBinding Light={StaticResource LightBorder}, Dark={StaticResource DarkBorder}}" StrokeShape="RoundRectangle 8" Padding="10,0">
                            <Entry Text="{Binding InputFleetCode}" Placeholder="{StaticResource SettingsInputPlaceholder}" />
                        </Border>
                        <Button Text="{StaticResource SettingsJoinBtn}" Command="{Binding JoinFleetCommand}" BackgroundColor="{StaticResource Primary}" TextColor="#000000" CornerRadius="8"/>
                    </VerticalStackLayout>

                    <!-- Si YA tiene jefe -->
                    <Border IsVisible="{Binding HasBoss}" Stroke="{StaticResource Primary}" StrokeShape="RoundRectangle 8" Padding="15" BackgroundColor="{AppThemeBinding Light={StaticResource LightButtonSec}, Dark={StaticResource DarkButtonSec}}">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✅" VerticalOptions="Center"/>
                            <Label Text="{StaticResource SettingsWorkingFor}" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource LightTextSub}, Dark={StaticResource DarkTextSub}}"/>
                            <Label Text="{Binding CurrentBossName}" FontAttributes="Bold" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource LightText}, Dark={StaticResource DarkText}}"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource LightDivider}, Dark={StaticResource DarkDivider}}" Margin="0,10"/>

                <!-- CERRAR SESIÓN -->
                <Button Text="{StaticResource SettingsLogoutBtn}" Command="{Binding LogoutCommand}" BackgroundColor="{StaticResource Error}" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="50"/>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="50" HeightRequest="50"/>
    </Grid>
</ContentPage>